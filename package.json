{
  "name": "mmf-blog-vite-vue3",
  "type": "module",
  "version": "1.25.1029",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "author": "lincenying <lincenying@qq.com>",
  "engines": {
    "node": ">=16.13.0"
  },
  "scripts": {
    "prepare[-del]": "npx simple-git-hooks",
    "del": "sh delete-ts.sh",
    "serve": "cross-env DEBUG=vite:transform vite",
    "build": "tsx polyfill.ts && vite build",
    "start": "vite preview --port 7776",
    "workbox": "workbox generateSW workbox-config.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:ts": "vue-tsc -b --noEmit"
  },
  "dependencies": {
    "@kangc/v-md-editor": "catalog:prod",
    "@lincy/utils": "catalog:prod",
    "@unhead/vue": "catalog:prod",
    "@vueuse/core": "catalog:prod",
    "axios": "catalog:prod",
    "element-plus": "catalog:prod",
    "js-cookie": "catalog:prod",
    "lodash": "catalog:prod",
    "md5": "catalog:prod",
    "mockjs": "catalog:prod",
    "pinia": "catalog:prod",
    "prismjs": "catalog:prod",
    "qs": "catalog:prod",
    "store2": "catalog:prod",
    "vue": "catalog:prod",
    "vue-content-loader": "catalog:prod",
    "vue-loading-overlay": "catalog:prod",
    "vue-router": "catalog:prod"
  },
  "devDependencies": {
    "@lincy/eslint-config": "catalog:lint",
    "@lincy/stylelint-config": "catalog:lint",
    "@lincy/unocss-base-config": "catalog:dev",
    "@types/js-cookie": "catalog:types",
    "@types/lodash": "catalog:types",
    "@types/md5": "catalog:types",
    "@types/polyfill-library": "catalog:types",
    "@types/prismjs": "catalog:types",
    "@types/qs": "catalog:types",
    "@unocss/eslint-plugin": "catalog:lint",
    "@unocss/preset-mini": "catalog:dev",
    "@vitejs/plugin-vue": "catalog:dev",
    "@vitejs/plugin-vue-jsx": "catalog:dev",
    "cross-env": "catalog:dev",
    "eslint": "catalog:lint",
    "eslint-plugin-format": "catalog:lint",
    "lint-staged": "catalog:dev",
    "polyfill-library": "catalog:dev",
    "postcss": "catalog:dev",
    "sass-embedded": "catalog:dev",
    "simple-git-hooks": "catalog:dev",
    "stylelint": "catalog:lint",
    "tsx": "catalog:dev",
    "typescript": "catalog:dev",
    "unocss": "catalog:dev",
    "unplugin-auto-import": "catalog:dev",
    "unplugin-vue-components": "catalog:dev",
    "unplugin-vue-macros": "catalog:dev",
    "vite": "catalog:dev",
    "vite-plugin-mock": "catalog:dev",
    "vite-plugin-pwa": "catalog:dev",
    "vue-tsc": "catalog:dev",
    "workbox-cli": "catalog:dev"
  },
  "simple-git-hooks[-del]": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged[-del]": {
    "*.{js,ts,tsx,vue}": [
      "eslint --fix"
    ]
  }
}
